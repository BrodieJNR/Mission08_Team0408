@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-12">
        <div class="p-4 p-md-5 mb-4 bg-light rounded-3">
            <div class="container-fluid py-2">
                <h1 class="display-6 fw-bold">Stephen Covey Task Quadrants</h1>
                <p class="col-md-10 fs-5">
                    Organize tasks by urgency and importance. Add tasks, then review incomplete tasks in the Quadrants view.
                </p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-primary btn-lg" asp-controller="Task" asp-action="Add">Add Task</a>
                    <a class="btn btn-outline-primary btn-lg" asp-controller="Task" asp-action="Quadrants">View Quadrants</a>
                </div>
            </div>
        </div>
    </div>
</div>
